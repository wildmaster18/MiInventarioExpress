<!-- Vista con el formulario para editar un producto existente -->
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">
                    <i class="bi bi-pencil-square me-2"></i>Editar Producto
                </h4>
            </div>
            <div class="card-body">

                <!-- Incluye el parcial de errores de validación -->
                {{> mensajeError}}

                <!-- Formulario de edición con método POST hacia la ruta de actualización -->
                <form action="/productos/editar/{{producto._id}}" method="POST" enctype="multipart/form-data">

                    <!-- Campo: Nombre del producto (pre-cargado con el valor actual) -->
                    <div class="mb-3">
                        <label for="nombre" class="form-label fw-semibold">
                            Nombre del producto <span class="text-danger">*</span>
                        </label>
                        <input type="text"
                               id="nombre"
                               name="nombre"
                               class="form-control"
                               value="{{producto.nombre}}">
                    </div>

                    <!-- Campo: Precio (pre-cargado con el valor actual) -->
                    <div class="mb-3">
                        <label for="precio" class="form-label fw-semibold">
                            Precio (USD) <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number"
                                   id="precio"
                                   name="precio"
                                   class="form-control"
                                   step="0.01"
                                   min="0"
                                   value="{{producto.precio}}">
                        </div>
                    </div>

                    <!-- Campo: Descripción (pre-cargada con el valor actual) -->
                    <div class="mb-3">
                        <label for="descripcion" class="form-label fw-semibold">
                            Descripción
                        </label>
                        <textarea id="descripcion"
                                  name="descripcion"
                                  class="form-control"
                                  rows="3">{{producto.descripcion}}</textarea>
                    </div>

                    <!-- Muestra la imagen actual si el producto tiene una -->
                    {{#if producto.imagen}}
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Imagen actual</label>
                            <div>
                                <img src="/uploads/{{producto.imagen}}"
                                     alt="{{producto.nombre}}"
                                     class="img-thumbnail"
                                     style="height: 120px; object-fit: cover;">
                            </div>
                        </div>
                    {{/if}}

                    <!-- Campo: Nueva imagen (opcional, reemplaza la actual si se sube una) -->
                    <div class="mb-4">
                        <label for="imagen" class="form-label fw-semibold">
                            {{#if producto.imagen}}Cambiar imagen{{else}}Agregar imagen{{/if}}
                        </label>
                        <input type="file"
                               id="imagen"
                               name="imagen"
                               class="form-control"
                               accept="image/jpeg, image/png">
                        <div class="form-text">Solo JPG o PNG, máximo 2 MB. Deja vacío para mantener la imagen actual.</div>
                    </div>

                    <!-- Botones de acción -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning flex-grow-1">
                            <i class="bi bi-save me-1"></i>Actualizar producto
                        </button>
                        <a href="/productos" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
