<!-- Vista principal: lista todos los productos registrados -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">
        <i class="bi bi-box-seam me-2 text-primary"></i>Inventario de Productos
    </h2>
    <a href="/productos/nuevo" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Nuevo producto
    </a>
</div>

{{#if productos.length}}
    <!-- Tabla que muestra los productos cuando la lista no está vacía -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col" style="width: 80px;">Imagen</th>
                        <th scope="col">Nombre</th>
                        <th scope="col">Precio</th>
                        <th scope="col">Descripción</th>
                        <th scope="col" class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each productos}}
                        <tr>
                            <td>
                                {{#if this.imagen}}
                                    <!-- Muestra la imagen del producto si existe -->
                                    <img src="/uploads/{{this.imagen}}"
                                         alt="{{this.nombre}}"
                                         class="img-thumbnail"
                                         style="width: 60px; height: 60px; object-fit: cover;">
                                {{else}}
                                    <!-- Ícono de sustitución si no hay imagen -->
                                    <div class="bg-secondary rounded d-flex align-items-center justify-content-center"
                                         style="width: 60px; height: 60px;">
                                        <i class="bi bi-image text-white fs-4"></i>
                                    </div>
                                {{/if}}
                            </td>
                            <td class="fw-semibold">{{this.nombre}}</td>
                            <td>
                                <span class="badge bg-success fs-6">$ {{this.precio}}</span>
                            </td>
                            <td class="text-muted">
                                {{#if this.descripcion}}
                                    {{this.descripcion}}
                                {{else}}
                                    <em>Sin descripción</em>
                                {{/if}}
                            </td>
                            <td class="text-center">
                                <!-- Botón para editar el producto -->
                                <a href="/productos/editar/{{this._id}}"
                                   class="btn btn-warning btn-sm me-1">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                                <!-- Formulario para eliminar el producto con confirmación -->
                                <form action="/productos/eliminar/{{this._id}}"
                                      method="POST"
                                      class="d-inline"
                                      onsubmit="return confirm('¿Seguro que quieres eliminar este producto?')">
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash3"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
{{else}}
    <!-- Mensaje cuando no hay productos registrados -->
    <div class="text-center py-5">
        <i class="bi bi-inbox display-1 text-muted"></i>
        <p class="text-muted mt-3 fs-5">No hay productos registrados todavía.</p>
        <a href="/productos/nuevo" class="btn btn-primary mt-2">
            <i class="bi bi-plus-circle me-1"></i>Registrar el primero
        </a>
    </div>
{{/if}}
