<!-- Barra de navegación principal del proyecto -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">
        <!-- Logo y nombre de la aplicación -->
        <a class="navbar-brand fw-bold" href="/">
            <i class="bi bi-box-seam me-2"></i>MiInventarioExpress
        </a>

        <!-- Botón hamburguesa para móviles -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Links del menú -->
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto">
                {{#if usuario}}
                    <!-- Muestra estos links solo si hay sesión activa -->
                    <li class="nav-item">
                        <a class="nav-link" href="/productos">
                            <i class="bi bi-list-ul me-1"></i>Productos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/productos/nuevo">
                            <i class="bi bi-plus-circle me-1"></i>Nuevo producto
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/chat">
                            <i class="bi bi-chat-dots me-1"></i>Chat
                        </a>
                    </li>
                    <li class="nav-item ms-lg-3">
                        <span class="navbar-text text-warning me-2">
                            <i class="bi bi-person-circle me-1"></i>{{usuario.nomUsu}}
                        </span>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm" href="/auth/logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Salir
                        </a>
                    </li>
                {{else}}
                    <!-- Muestra estos links cuando no hay sesión activa -->
                    <li class="nav-item">
                        <a class="nav-link" href="/auth/login">Iniciar sesión</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/auth/registro">Registrarse</a>
                    </li>
                {{/if}}
            </ul>
        </div>
    </div>
</nav>
